(* Записи: создание, доступ к полям, присваивание полю, равенство. *)

<¤ ФАМ: "Петров", ИМЯ: "Иван", ВОЗРАСТ: 30 ¤> -> АНКЕТА;
? АНКЕТА.ФАМ;
? АНКЕТА.ИМЯ;
? АНКЕТА.ВОЗРАСТ;

(* Присваивание полю *)
"Сидоров" -> АНКЕТА.ФАМ;
31 -> АНКЕТА.ВОЗРАСТ;
? АНКЕТА.ФАМ, " ", АНКЕТА.ВОЗРАСТ;

(* $-форма скобок эквивалентна ¤-форме *)
<$ А: 1, Б: 2 $> -> Х;
? Х = <¤ А: 1, Б: 2 ¤>;

(* Чтение отсутствующего поля даёт .пусто *)
? АНКЕТА.НЕТ_ТАКОГО = .пусто;
