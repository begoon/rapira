(* Обе формы оператора ВЫБОР. *)

ПРОЦ ОПИСАТЬ (К);
   ВЫБОР К ИЗ
        1, 2 : ? "мало"
      ! 3, 4 : ? "несколько"
      ! 5    : ? "пять"
        ИНАЧЕ ? "много"
   ВСЕ
КНЦ;

ОПИСАТЬ(1);
ОПИСАТЬ(3);
ОПИСАТЬ(5);
ОПИСАТЬ(99);

0 -> Х;
ВЫБОР ИЗ
     Х > 0 : ? "ПОЛОЖ"
   ! Х < 0 : ? "ОТРИЦ"
     ИНАЧЕ   ? "НУЛЬ"
ВСЕ;
